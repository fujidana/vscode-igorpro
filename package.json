{
  "publisher": "fujidana",
  "name": "vscode-igorpro",
  "displayName": "Igor Pro",
  "description": "Igor Pro support for VS Code",
  "version": "2.2.0",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "technical graphing",
    "data analysis"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/fujidana/vscode-igorpro/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fujidana/vscode-igorpro.git"
  },
  "homepage": "https://github.com/fujidana/vscode-igorpro#readme",
  "activationEvents": [
    "onFileSystem:igorpro"
  ],
  "main": "./dist/node/extension.js",
  "browser": "./dist/web/extension.js",
  "l10n": "./l10n",
  "extensionKind": [
    "workspace"
  ],
  "contributes": {
    "languages": [
      {
        "id": "igorpro",
        "aliases": [
          "Igor Pro",
          "Igor Procedure File"
        ],
        "extensions": [
          ".ipf"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "igorpro",
        "scopeName": "source.igorpro",
        "path": "./syntaxes/igorpro.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "igorpro",
        "path": "./syntaxes/igorpro.snippets.json"
      }
    ],
    "commands": [
      {
        "command": "vscode-igorpro.showDictionaryPreview",
        "title": "%command.vscode-igorpro.showDictionaryPreview.title%",
        "category": "Igor Pro",
        "icon": "$(references)"
      },
      {
        "command": "vscode-igorpro.showDictionarySource",
        "title": "%command.vscode-igorpro.showDictionarySource.title%",
        "category": "Igor Pro",
        "icon": "$(repo-pull)"
      },
      {
        "command": "vscode-igorpro.registerDictionary",
        "title": "%command.vscode-igorpro.registerDictionary.title%",
        "enablement": "editorLangId == json",
        "category": "Igor Pro",
        "icon": "$(repo-push)"
      },
      {
        "command": "vscode-igorpro.deleteDictionary",
        "title": "%command.vscode-igorpro.deleteDictionary.title%",
        "category": "Igor Pro",
        "icon": "$(trash)"
      },
      {
        "command": "vscode-igorpro.inspectSyntaxTree",
        "title": "%command.vscode-igorpro.inspectSyntaxTree.title%",
        "category": "Igor Pro",
        "icon": "$(json)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "vscode-igorpro.showDictionaryPreview"
        },
        {
          "command": "vscode-igorpro.showDictionarySource"
        },
        {
          "command": "vscode-igorpro.registerDictionary",
          "when": "editorLangId == json"
        },
        {
          "command": "vscode-igorpro.deleteDictionary"
        },
        {
          "command": "vscode-igorpro.inspectSyntaxTree",
          "when": "editorLangId == igorpro"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": [
          "ipdict.json",
          "*.ipdict.json"
        ],
        "url": "./schema/ipdict.schema.json"
      }
    ],
    "configurationDefaults": {
      "[igorpro]": {
        "editor.insertSpaces": false
      }
    },
    "configuration": [
      {
        "title": "Igor Pro",
        "properties": {
          "vscode-igorpro.igorVersion": {
            "type": "string",
            "default": "10.00",
            "markdownDescription": "%configuration.vscode-igorpro.igorVersion.description%",
            "pattern": "^(0|[1-9]\\d*)\\.(\\d)(\\d)(?!\\d)",
            "patternErrorMessage": "%configuration.vscode-igorpro.igorVersion.patternErrorMessage%"
          },
          "vscode-igorpro.showSymbolsInPreview": {
            "type": "boolean",
            "default": true,
            "markdownDescription": "%configuration.vscode-igorpro.showSymbolsInPreview.description%",
            "markdownDeprecationMessage": "**Deprecated**: Please use `#vscode-igorpro.dictionaryPreview#` instead."
          },
          "vscode-igorpro.dictionaryPreview": {
            "type": "string",
            "enum": [
              "markdown",
              "preview",
              "markdown+preview"
            ],
            "default": "preview",
            "markdownDescription": "%configuration.vscode-igorpro.dictionaryPreview.description%"
          },
          "vscode-igorpro.suggest.suppressMessages": {
            "type": "object",
            "markdownDescription": "%configuration.vscode-igorpro.suggest.suppressMessages.description%",
            "default": {
              "completionItem.label.detail": false,
              "completionItem.label.description": false,
              "completionItem.documentation": false,
              "hover.contents": false,
              "signatureHelp.signatures.documentation": false
            },
            "properties": {
              "completionItem.label.detail": {
                "type": "boolean",
                "default": false,
                "description": "%configuration.vscode-igorpro.suggest.suppressMessages.completionItem.label.detail.description%"
              },
              "completionItem.label.description": {
                "type": "boolean",
                "default": false,
                "description": "%configuration.vscode-igorpro.suggest.suppressMessages.completionItem.label.description.description%"
              },
              "completionItem.documentation": {
                "type": "boolean",
                "default": false,
                "description": "%configuration.vscode-igorpro.suggest.suppressMessages.completionItem.documentation.description%"
              },
              "hover.contents": {
                "type": "boolean",
                "default": false,
                "description": "%configuration.vscode-igorpro.suggest.suppressMessages.hover.contents.description%"
              },
              "signatureHelp.signatures.documentation": {
                "type": "boolean",
                "default": false,
                "description": "%configuration.vscode-igorpro.suggest.suppressMessages.signatureHelp.signatures.documentation.description%"
              }
            },
            "additionalProperties": false
          },
          "vscode-igorpro.suggest.scope": {
            "type": "string",
            "default": "workspace",
            "scope": "resource",
            "markdownDescription": "%configuration.vscode-igorpro.suggest.scope.description%",
            "enum": [
              "workspace",
              "openDocuments",
              "activeEditor"
            ],
            "markdownEnumDescriptions": [
              "%configuration.vscode-igorpro.suggest.scope.workspace.enumDescription%",
              "%configuration.vscode-igorpro.suggest.scope.openDocuments.enumDescription%",
              "%configuration.vscode-igorpro.suggest.scope.activeEditor.enumDescription%"
            ],
            "tags": [
              "experimental"
            ]
          },
          "vscode-igorpro.suggest.symbolFile": {
            "type": "string",
            "default": "",
            "scope": "window",
            "markdownDescription": "%configuration.vscode-igorpro.suggest.symbolFile.description%",
            "markdownDeprecationMessage": "**Deprecated**: Not effective now."
          }
        }
      }
    ]
  },
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": "limited",
      "description": "%capabilities.untrustedWorkspaces.description%",
      "restrictedConfigurations": [
        "vscode-igorpro.suggest.symbolFile"
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run js-yaml && pnpm run package",
    "package": "pnpm run compile:peggy && pnpm run '/^(lint|compile:tsc|package:esbuild)$/'",
    "compile": "pnpm run compile:peggy && pnpm run '/^(lint|compile:tsc|compile:esbuild)$/'",
    "watch": "pnpm run '/^watch:.+/'",
    "lint": "eslint src",
    "compile:peggy": "peggy src/parser.peggy --dts --cache --return-types '{\"Start\": \"import(\\\"./tree\\\").Program\"}'",
    "watch:peggy": "peggy src/parser.peggy --dts --cache --return-types '{\"Start\": \"import(\\\"./tree\\\").Program\"}' --watch",
    "compile:tsc": "tsc --project . --noEmit",
    "watch:tsc": "tsc --project . --noEmit --watch --preserveWatchOutput",
    "package:esbuild": "node esbuild.js --production",
    "compile:esbuild": "node esbuild.js",
    "watch:esbuild": "node esbuild.js --watch",
    "compile-tests": "tsc --project . --outDir out",
    "watch-tests": "tsc --project . --outDir out --watch --preserveWatchOutput",
    "pretest": "pnpm run compile:peggy && pnpm run compile-tests",
    "test": "vscode-test",
    "pretest-web": "pnpm run compile",
    "test-web": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. --extensionTestsPath=dist/web/test/extensionTests.js",
    "run-in-browser": "vscode-test-web --browserType=chromium --extensionDevelopmentPath=. .",
    "js-yaml": "pnpm run '/^js-yaml:.+/'",
    "js-yaml:snippets": "js-yaml syntaxes/igorpro.snippets.yaml > syntaxes/igorpro.snippets.json",
    "js-yaml:tmLanguage": "js-yaml syntaxes/igorpro.tmLanguage.yaml > syntaxes/igorpro.tmLanguage.json",
    "js-yaml:ipdict": "js-yaml syntaxes/igorpro.ipdict.yaml > syntaxes/igorpro.ipdict.json",
    "l10n-export": "pnpm dlx @vscode/l10n-dev export -o ./l10n ./src"
  },
  "dependencies": {
    "estraverse": "^5.3.0",
    "semver": "^7.8.0"
  },
  "devDependencies": {
    "@esbuild-plugins/node-globals-polyfill": "^0.2.3",
    "@esbuild-plugins/node-modules-polyfill": "^0.2.2",
    "@types/assert": "^1.5.11",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/semver": "^7.7.1",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/test-web": "^0.0.80",
    "assert": "^2.1.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "glob": "^13.0.6",
    "js-yaml": "^4.1.1",
    "mocha": "^11.7.6",
    "peggy": "^5.1.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4"
  }
}